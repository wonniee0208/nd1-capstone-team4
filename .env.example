# ─── ND1 캡스톤 환경변수 (이 파일을 .env 로 복사해서 사용) ───
# groq API 키 발급: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Node A LLM 모델
#  ※ 2026-06-17 부로 llama-3.1-8b-instant / llama-3.3-70b-versatile deprecated.
#    현재 권장: openai/gpt-oss-20b (경량·빠름) / openai/gpt-oss-120b (고성능)
#    최신 유효 모델은 https://console.groq.com/docs/models 에서 확인.
GROQ_MODEL=openai/gpt-oss-20b

# ROS2 도메인 (팀별 충돌 방지 — 팀마다 다른 값 권장)
ROS_DOMAIN_ID=42
